{
	"compilerOptions": {
		/* このファイルの詳細については https://aka.ms/tsconfig.json を参照してください */

		/* 出力される JavaScript の言語バージョンを設定し、互換性のあるライブラリ宣言を含めます。 */
		"target": "es2021",
		/* ターゲットランタイム環境を記述する組み込みライブラリ宣言ファイルのセットを指定します。 */
		"lib": ["es2021"],
		/* 生成される JSX コードの種類を指定します。 */
		"jsx": "react-jsx",

		/* 生成されるモジュールコードの種類を指定します。 */
		"module": "es2022",
		/* TypeScript がモジュール指定子からファイルを解決する方法を指定します。 */
		"moduleResolution": "Bundler",
		/* ソースファイルで参照されていなくても含める型パッケージ名を指定します。 */
		"types": [
			"@cloudflare/workers-types/2023-07-01"
		],
		/* .json ファイルのインポートを有効にします */
		"resolveJsonModule": true,

		/* JavaScript ファイルをプログラムの一部として含めることを許可します。`checkJS` オプションでエラーチェックを有効にできます。 */
		"allowJs": true,
		/* 型チェックされた JavaScript ファイルでのエラー報告を有効にします。 */
		"checkJs": false,

		/* コンパイル時にファイルを出力しません。 */
		"noEmit": true,

		/* 各ファイルが他のインポートに依存せず単独でトランスパイルできることを保証します。 */
		"isolatedModules": true,
		/* デフォルトエクスポートがないモジュールでも 'import x from y' を許可します。 */
		"allowSyntheticDefaultImports": true,
		/* インポートのファイル名の大文字・小文字が正しいことを確認します。 */
		"forceConsistentCasingInFileNames": true,

		/* すべての厳格な型チェックオプションを有効にします。 */
		"strict": true,

		/* すべての .d.ts ファイルの型チェックをスキップします。 */
		"skipLibCheck": true
	},
	"exclude": ["test"],
	"include": ["worker-configuration.d.ts", "functions/**/*.ts"]
}
